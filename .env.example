# CabinetLog — Production Environment Variables
# Copy this file to .env and fill in production values.

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
MONGODB_URI=mongodb://admin:changeme@mongodb:27017/cabinetlog?authSource=admin

# JWT Authentication
JWT_SECRET=change-this-secret-in-production

# CORS — set to the public URL of your frontend
CORS_ORIGIN=http://localhost

# File uploads (path inside container)
UPLOAD_DIR=/app/uploads
