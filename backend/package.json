{
  "name": "cabinetlog-backend",
  "version": "1.0.0",
  "private": true,
  "description": "CabinetLog Backend — Express.js API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "seed": "ts-node src/scripts/seed.ts",
    "db:indexes": "ts-node src/scripts/createIndexes.ts",
    "demo": "ts-node src/scripts/demoGuide.ts"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.9.5",
    "multer": "1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "sharp": "0.33.5",
    "uuid": "11.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.7",
    "@types/multer": "1.4.12",
    "@types/node": "22.10.5",
    "@types/pdfkit": "^0.13.8",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.2",
    "fast-check": "3.23.2",
    "jest": "29.7.0",
    "mongodb-memory-server": "10.1.2",
    "prettier": "3.4.2",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.7.3"
  }
}
